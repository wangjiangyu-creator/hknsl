---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import PageHeader from "../../../components/PageHeader.astro";
import RecordCard from "../../../components/RecordCard.astro";
import { topics } from "../../../data/topics.js";
import { locales, localized, t } from "../../../lib/i18n.js";
import { getTopic, recordsForTopic } from "../../../lib/content.js";

export function getStaticPaths() {
  return locales.flatMap((lang) => topics.map((topic) => ({ params: { lang, id: topic.id } })));
}

const { lang, id } = Astro.params;
const locale = lang;
const topic = getTopic(id);
const items = recordsForTopic(id);
---

<SiteLayout locale={locale} current="topics" title={localized(topic.title, locale)} description={localized(topic.summary, locale)}>
  <PageHeader eyebrow={t(locale, "topics")} title={localized(topic.title, locale)} deck={localized(topic.summary, locale)} />
  <section class="section">
    <article class="topic-card">
      <h2>{t(locale, "issue")}</h2>
      <ul>
        {localized(topic.questions, locale).map((question) => <li>{question}</li>)}
      </ul>
    </article>
  </section>
  <section class="section">
    <div class="section-header">
      <h2>{t(locale, "relatedTopics")}</h2>
      <p>{items.length} {t(locale, "recordCount")}</p>
    </div>
    <div class="record-grid">
      {items.map((record) => <RecordCard record={record} locale={locale} />)}
    </div>
  </section>
</SiteLayout>
